">

    <h3>C# Implementation</h3>

<pre>
using System;

class PrismatoidCalculator
{
    static void Main()
    {
        double baseArea = 10;
        double middleArea = 12;
        double topArea = 8;
        double height = 5;

        double volume;

        volume = (height / 6) * (baseArea + 4 * middleArea + topArea);

        Console.WriteLine("Volume = " + volume);
    }
}
